exports[`renderToText > matches snapshot for box-arrows.yaml 1`] = `
"

  ┌────────────────┐
  │                ◀────────── response ───────────┐┌──────────────┐
  │     Client     │                               └╴    Server    │
  │                │          ┌──────────── forward ▶              │
  │                ╶─ request ▶ Edge Proxy ╶─┘      └──────────────┘
  └────────────────┘          └────────────┘

Nodes:
- client: Client
- proxy: Edge Proxy
- server: Server

Edges:
- client -> proxy: request
- proxy -> server: forward
- server -> client: response
"
`;

