{
  "name": "cora",
  "version": "0.0.0",
  "description": "Diagram tool for AI coding agents — YAML in, SVG/PNG out",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "cora": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./renderer": {
      "import": "./dist/renderer/index.js",
      "types": "./dist/renderer/index.d.ts"
    },
    "./renderer/components": {
      "import": "./dist/renderer/components/index.js",
      "types": "./dist/renderer/components/index.d.ts"
    }
  },
  "files": [
    "dist",
    ".npmrc",
    "SKILL.md"
  ],
  "scripts": {
    "generate:icon-index": "node scripts/generate-icon-index.mjs",
    "build": "node scripts/sync-diagram-fonts.mjs && tsdown && vite build src/preview --base ./ --outDir ../../preview-dist --emptyOutDir && mkdir -p dist/renderer/assets && cp -r src/renderer/assets/fonts dist/renderer/assets/",
    "cora": "node dist/cli.js",
    "dev": "tsdown --watch",
    "prepack": "cp ../../SKILL.md SKILL.md",
    "postpack": "rm -f SKILL.md",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:golden": "node tests/render-golden.mjs",
    "postinstall": "node -e \"console.log('cora: Chromium for --quality=high is downloaded on first use; see AGENTS.md')\""
  },
  "dependencies": {
    "@iconify-json/basil": "^1.2.4",
    "@iconify-json/material-symbols": "^1.2.74",
    "@iconify/types": "^2.0.0",
    "@iconify/utils": "^3.1.3",
    "@pdf-lib/fontkit": "^1.1.1",
    "@resvg/resvg-js": "~2.6.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "elkjs": "^0.11.1",
    "env-paths": "^4.0.0",
    "fontkit": "^2.0.4",
    "pdf-lib": "^1.17.1",
    "picocolors": "^1.1.1",
    "playwright": "^1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "web-worker": "^1.5.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/lato": "^5.2.7",
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/noto-sans": "5.2.5",
    "@fontsource/open-sans": "^5.2.7",
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@fontsource/raleway": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/source-sans-3": "^5.2.9",
    "@iconify/json": "^2.2.479",
    "@types/node": "^22.15.21",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "pdf-parse": "^2.4.5",
    "tsdown": "^0.22.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
